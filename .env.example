# App URLs
VITE_APP_URL=http://localhost:5173
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Default provider when no browser-stored config exists: anthropic | openai | gemini
VITE_DEFAULT_PROVIDER=anthropic

# Optional client-side API key fallbacks (used only when no saved key exists)
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=

# Anthropic models by speed mode
VITE_ANTHROPIC_MODEL_FAST=claude-sonnet-4-6-20250514
VITE_ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6-20250514
VITE_ANTHROPIC_MODEL_QUALITY=claude-sonnet-4-6-20250514

# OpenAI models by speed mode
VITE_OPENAI_MODEL_FAST=gpt-5.2
VITE_OPENAI_MODEL_BALANCED=gpt-5.2
VITE_OPENAI_MODEL_QUALITY=gpt-5.2

# Gemini models by speed mode
VITE_GEMINI_MODEL_FAST=gemini-3.0-pro
VITE_GEMINI_MODEL_BALANCED=gemini-3.0-pro
VITE_GEMINI_MODEL_QUALITY=gemini-3.0-pro
